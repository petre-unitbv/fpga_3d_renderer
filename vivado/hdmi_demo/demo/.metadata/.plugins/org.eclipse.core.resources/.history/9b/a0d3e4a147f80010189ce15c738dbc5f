void DemoChangeRes()
{
    char userInput = 0;
    int fResSet = 0;
    int status = XST_SUCCESS;

    while (!fResSet)
    {
        DemoCRMenu();

        while (!XUartPs_IsReceiveData(UART_BASEADDR)) {}

        userInput = XUartPs_ReadReg(UART_BASEADDR, XUARTPS_FIFO_OFFSET);
        xil_printf("%c", userInput);

        switch (userInput)
        {
            case '1': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_640x480); fResSet = 1; break;
            case '2': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_800x600); fResSet = 1; break;
            case '3': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_1280x720); fResSet = 1; break;
            case '4': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_1280x1024); fResSet = 1; break;
            case '5': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_1600x900); fResSet = 1; break;
            case '6': DisplayStop(&dispCtrl); DisplaySetMode(&dispCtrl, &VMODE_1920x1080); fResSet = 1; break;
            case 'q': fResSet = 1; break;
            default: xil_printf("\n\rInvalid Selection"); TimerDelay(500000); break;
        }

        if (status == XST_DMA_ERROR)
            xil_printf("\n\rWARNING: AXI VDMA Error detected and cleared\n\r");
    }
}

void DemoRun()
{
    char userInput = 0;

    while (XUartPs_IsReceiveData(UART_BASEADDR))
        XUartPs_ReadReg(UART_BASEADDR, XUARTPS_FIFO_OFFSET);

    while (userInput != 'q')
    {
        fRefresh = 0;
        DemoPrintMenu();

        while (!XUartPs_IsReceiveData(UART_BASEADDR) && !fRefresh) {}

        if (XUartPs_IsReceiveData(UART_BASEADDR))
        {
            userInput = XUartPs_ReadReg(UART_BASEADDR, XUARTPS_FIFO_OFFSET);
            xil_printf("%c", userInput);
        }
        else
        {
            userInput = 'r';
        }

        switch (userInput)
        {
            case '1': DemoChangeRes(); break;
            case 'q': break;
            case 'r': break;
            default:
                xil_printf("\n\rInvalid Selection");
                TimerDelay(500000);
        }
    }
}

void DemoISR(void *callBackRef, void *pVideo)
{
    char *data = (char *)callBackRef;
    *data = 1;
}

int main(void)
{
    DemoInitialize();
    DemoRun();
    return 0;
}
