void DemoPrintTest(u8 *frame, u32 width, u32 height, u32 stride, int pattern)
{
    u32 xcoi, ycoi;
    u32 iPixelAddr;

    switch (pattern)
    {
        case DEMO_PATTERN_0:
            for (ycoi = 0; ycoi < height; ycoi++)
            {
                iPixelAddr = ycoi * stride;
                for (xcoi = 0; xcoi < width; xcoi++)
                {
                    u32 idx = iPixelAddr + (xcoi * 3);

                    if (xcoi < (5 * width) / 16)
                    {
                        if (ycoi < (4 * height) / 10)
                            PutPixel(frame, stride, xcoi, ycoi, 131, 85, 0);
                        else if (ycoi < (6 * height) / 10)
                            PutPixel(frame, stride, xcoi, ycoi, 0, 194, 255);
                        else
                            PutPixel(frame, stride, xcoi, ycoi, 131, 85, 0);
                    }
                    else if (xcoi < (7 * width) / 16)
                    {
                        PutPixel(frame, stride, xcoi, ycoi, 0, 194, 255);
                    }
                    else
                    {
                        if (ycoi < (4 * height) / 10)
                            PutPixel(frame, stride, xcoi, ycoi, 131, 85, 0);
                        else if (ycoi < (6 * height) / 10)
                            PutPixel(frame, stride, xcoi, ycoi, 0, 194, 255);
                        else
                            PutPixel(frame, stride, xcoi, ycoi, 131, 85, 0);
                    }
                }
            }
            FlushFrame(frame, height, stride);
            break;

        case DEMO_PATTERN_1:
            for (ycoi = 0; ycoi < height; ycoi++)
            {
                iPixelAddr = ycoi * stride;
                for (xcoi = 0; xcoi < width; xcoi++)
                {
                    if (xcoi < width / 3)
                        PutPixel(frame, stride, xcoi, ycoi, 38, 17, 206);
                    else if (xcoi < (2 * width) / 3)
                        PutPixel(frame, stride, xcoi, ycoi, 22, 209, 252);
                    else
                        PutPixel(frame, stride, xcoi, ycoi, 127, 43, 0);
                }
            }
            FlushFrame(frame, height, stride);
            break;

        case DEMO_PATTERN_2:
        {
            for (ycoi = 0; ycoi < height; ycoi++)
            {
                iPixelAddr = ycoi * stride;
                for (xcoi = 0; xcoi < width; xcoi++)
                    PutPixel(frame, stride, xcoi, ycoi, 0, 0, 0);
            }

            FillRectSafe(frame, stride, width, height, width / 5, height / 4, 50, 50, 0, 255, 0);
            FillRectSafe(frame, stride, width, height, width / 2, height / 2, 50, 50, 0, 255, 0);

            FlushFrame(frame, height, stride);
            break;
        }

        default:
            xil_printf("Error: invalid pattern passed to DemoPrintTest\r\n");
            break;
    }
}

void DemoISR(void *callBackRef, void *pVideo)
{
    char *data = (char *)callBackRef;
    *data = 1;
}
