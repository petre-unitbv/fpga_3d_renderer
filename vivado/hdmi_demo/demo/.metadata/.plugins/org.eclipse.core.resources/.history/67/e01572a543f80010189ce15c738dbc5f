VideoCapture videoCapt;
INTC intc;
char fRefresh; // flag used to trigger menu refresh on video detect

/*
 * Framebuffers for video data
 */
u8 frameBuf[DISPLAY_NUM_FRAMES][DEMO_MAX_FRAME] __attribute__((aligned(0x20)));
u8 *pFrames[DISPLAY_NUM_FRAMES]; // array of pointers to the frame buffers

/*
 * Interrupt vector table
 */
const ivt_t ivt[] = {
    videoGpioIvt(HDMI_IN_GPIO_IRPT_ID, &videoCapt),
    videoVtcIvt(HDMI_IN_VTC_IRPT_ID, &(videoCapt.vtc))
};

/* ------------------------------------------------------------ */
/*              Internal helper declarations                      */
/* ------------------------------------------------------------ */

static inline void PutPixel(u8 *frame, u32 stride, u32 x, u32 y, u8 b, u8 g, u8 r)
{
    u32 idx = y * stride + (x * 3);
    frame[idx + 0] = b;
    frame[idx + 1] = g;
    frame[idx + 2] = r;
}

static void FillRectSafe(u8 *frame, u32 stride, u32 width, u32 height,
                         u32 x, u32 y, u32 w, u32 h,
                         u8 b, u8 g, u8 r)
{
    if (x >= width || y >= height)
        return;

    u32 xEnd = x + w;
    u32 yEnd = y + h;

    if (xEnd > width) xEnd = width;
    if (yEnd > height) yEnd = height;

    for (u32 yy = y; yy < yEnd; yy++)
    {
        u32 idx = yy * stride + (x * 3);
        for (u32 xx = x; xx < xEnd; xx++)
        {
            frame[idx + 0] = b;
            frame[idx + 1] = g;
            frame[idx + 2] = r;
            idx += 3;
        }
    }
}

static void FlushFrame(u8 *frame, u32 height, u32 stride)
{
    Xil_DCacheFlushRange((unsigned int)frame, height * stride);
}

