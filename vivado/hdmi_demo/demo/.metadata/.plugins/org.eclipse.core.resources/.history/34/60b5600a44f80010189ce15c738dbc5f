void DrawFilledRect(
    u8 *frame,
    u32 stride,
    u32 x,
    u32 y,
    u32 rectWidth,
    u32 rectHeight,
    u8 blue,
    u8 green,
    u8 red
)
{
    u32 xi, yi;
    u32 pixel_index;

    for (yi = y; yi < y + rectHeight; yi++)
    {
        pixel_index = yi * stride + (x * 3);

        for (xi = 0; xi < rectWidth; xi++)
        {
            frame[pixel_index + 0] = blue;
            frame[pixel_index + 1] = green;
            frame[pixel_index + 2] = red;

            pixel_index += 3;
        }
    }
}


void DemoPrintTest(u8 *frame, u32 width, u32 height, u32 stride, int pattern)
{
	u32 xcoi, ycoi;
	u32 iPixelAddr;



	switch (pattern)
	{
	case DEMO_PATTERN_0:



			    for (ycoi = 0; ycoi < height; ycoi++)
			    {
			        // start of this row in memory
			        iPixelAddr = ycoi * stride;

			        for (xcoi = 0; xcoi < width; xcoi++)
			        {
			            /*
			             * xcoi is in PIXELS here (not bytes)
			             * Each pixel is 3 bytes
			             */
			            u32 pixel_index = iPixelAddr + (xcoi * 3);
			            u32 xPixel = xcoi;

			            if (xPixel < (5 * width) / 16)
			            {
			                if (ycoi < (4 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 131;
			                    frame[pixel_index + 1] = 85;
			                    frame[pixel_index + 2] = 0;
			                }
			                else if (ycoi < (6 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 0;//Blue
			                    frame[pixel_index + 1] = 194;//Green
			                    frame[pixel_index + 2] = 255;//Red
			                }
			                else
			                {
			                    frame[pixel_index + 0] = 131;
			                    frame[pixel_index + 1] = 85;
			                    frame[pixel_index + 2] = 0;
			                }
			            }
			            else if (xPixel < (7 * width) / 16)
			            {
			                if (ycoi < (4 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 0;
			                    frame[pixel_index + 1] = 194;
			                    frame[pixel_index + 2] = 255;
			                }
			                else if (ycoi < (6 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 0;
			                    frame[pixel_index + 1] = 194;
			                    frame[pixel_index + 2] = 255;
			                }
			                else
			                {
			                    frame[pixel_index + 0] = 0;
			                    frame[pixel_index + 1] = 194;
			                    frame[pixel_index + 2] = 255;
			                }
			            }
			            else
			            {
			                if (ycoi < (4 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 131;
			                    frame[pixel_index + 1] = 85;
			                    frame[pixel_index + 2] = 0;
			                }
			                else if (ycoi < (6 * height) / 10)
			                {
			                    frame[pixel_index + 0] = 0;
			                    frame[pixel_index + 1] = 194;
			                    frame[pixel_index + 2] = 255;
			                }
			                else
			                {
			                    frame[pixel_index + 0] = 131;
			                    frame[pixel_index + 1] = 85;
			                    frame[pixel_index + 2] = 0;
			                }
			            }


			        }
			    }

				Xil_DCacheFlushRange((unsigned int) frame, DEMO_MAX_FRAME);
				break;


	case DEMO_PATTERN_1:


		    for (ycoi = 0; ycoi < height; ycoi++)
		    {
		        // start of this row in memory
		        iPixelAddr = ycoi * stride;

		        for (xcoi = 0; xcoi < width; xcoi++)
		        {
		            /*
		             * xcoi is in PIXELS here (not bytes)
		             * Each pixel is 3 bytes
		             */
		            u32 pixel_index = iPixelAddr + (xcoi * 3);

		            if (xcoi < width / 3)
		            {
		                // Section A: Red
		                frame[pixel_index + 0] = 38;
		                frame[pixel_index + 1] = 17;
		                frame[pixel_index + 2] = 206;//Red
		            }
		            else if (xcoi < (2 * width) / 3)
		            {
		                // Section B: Yellow (Red + Green)
		                frame[pixel_index + 0] = 22;
		                frame[pixel_index + 1] = 209; //Green
		                frame[pixel_index + 2] = 252; // Red
		            }
		            else
		            {
		                // Section C: Green
		                frame[pixel_index + 0] = 127; //Blue
		                frame[pixel_index + 1] = 43;
		                frame[pixel_index + 2] = 0;
		            }
		        }
		    }

			Xil_DCacheFlushRange((unsigned int) frame, DEMO_MAX_FRAME);
			break;

	case DEMO_PATTERN_2:
	{
	    const u32 rectW = 50;
	    const u32 rectH = 50;

	    /* Clear screen (black) */
	    for (ycoi = 0; ycoi < height; ycoi++)
	    {
	        iPixelAddr = ycoi * stride;
	        for (xcoi = 0; xcoi < width; xcoi++)
	        {
	            u32 p = iPixelAddr + (xcoi * 3);
	            frame[p + 0] = 0;
	            frame[p + 1] = 0;
	            frame[p + 2] = 0;
	        }
	    }

	    /* Two fixed positions (simple, deterministic) */
	    DrawFilledRect(frame, stride, width / 5,  height / 4, rectW, rectH, 0, 255, 0);
	    DrawFilledRect(frame, stride, width / 2,  height / 2, rectW, rectH, 0, 255, 0);

	    Xil_DCacheFlushRange((unsigned int)frame, DEMO_MAX_FRAME);
	    break;
	}




	default :
		xil_printf("Error: invalid pattern passed to DemoPrintTest");
	}
}

void DemoISR(void *callBackRef, void *pVideo)
{
	char *data = (char *) callBackRef;
	*data = 1; //set fRefresh to 1
}


