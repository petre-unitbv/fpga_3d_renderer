<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_rotation_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_rotation" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="140.201 ns"></ZoomEndTime>
      <Cursor1Time time="26.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="161"></NameColumnWidth>
      <ValueColumnWidth column_width="178"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="18" />
   <wvobject type="logic" fp_name="/tb_rotation/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_rotation/rst_n">
      <obj_property name="ElementShortName">rst_n</obj_property>
      <obj_property name="ObjectShortName">rst_n</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_rotation/start">
      <obj_property name="ElementShortName">start</obj_property>
      <obj_property name="ObjectShortName">start</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_rotation/rotation">
      <obj_property name="ElementShortName">rotation[2:0]</obj_property>
