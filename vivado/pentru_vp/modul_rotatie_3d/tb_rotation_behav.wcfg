      <obj_property name="ElementShortName">valid</obj_property>
      <obj_property name="ObjectShortName">valid</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_rotation/overflow">
      <obj_property name="ElementShortName">overflow</obj_property>
