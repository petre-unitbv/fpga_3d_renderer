      <obj_property name="ObjectShortName">z[31:0]</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_rotation/angle">
      <obj_property name="ElementShortName">angle[9:0]</obj_property>
      <obj_property name="ObjectShortName">angle[9:0]</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_rotation/xr">
      <obj_property name="ElementShortName">xr[31:0]</obj_property>
      <obj_property name="ObjectShortName">xr[31:0]</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_rotation/yr">
      <obj_property name="ElementShortName">yr[31:0]</obj_property>
