   <column_width_setting>
      <NameColumnWidth column_width="162"></NameColumnWidth>
      <ValueColumnWidth column_width="71"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="7" />
   <wvobject type="array" fp_name="/tb_project/tb_x">
